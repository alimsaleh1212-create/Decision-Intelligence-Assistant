# =============================================================================
# Decision Intelligence Assistant — environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Ollama (primary LLM + embeddings)
# Inside Docker the service is reachable at http://ollama:11434.
# For local dev outside Docker use http://localhost:11434.
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=gemma4:31b-cloud
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# Gemini (fallback LLM — optional)
# Leave GOOGLE_API_KEY blank or unset to disable the fallback entirely.
# When Ollama is unreachable the backend will fall back to gemini-2.5-flash.
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=
GEMINI_LLM_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Qdrant vector store
# Inside Docker use the service name; outside Docker use localhost.
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=support_tickets
QDRANT_TOP_K=5

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=/app/logs

# -----------------------------------------------------------------------------
# Frontend (Vite build-time variable — must start with VITE_)
# Point at the backend. In production set this to your deployed backend URL.
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
