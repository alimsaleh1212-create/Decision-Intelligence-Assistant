# ── LLM (Ollama — primary) ───────────────────────────────────────────────────
# Override the model tag if you want a different local model.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=gemma4:31b-cloud
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT_SECONDS=30

# ── LLM (Gemini — optional fallback) ────────────────────────────────────────
# Leave blank to disable the fallback. Ollama errors will surface directly.
GOOGLE_API_KEY=

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=support_tickets
QDRANT_TOP_K=5

# ── Backend ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=/app/logs
